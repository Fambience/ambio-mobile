/* ==== ADDITIONAL OVERRIDES TO PREVENT BLUE ==== */
/* Target any potential selection styling */
.unity-popup-field:focus,
.unity-popup-field:active,
.unity-base-popup-field:focus,
.unity-base-popup-field:active {
    background-color: white !important;
    border-color: #ccc !important;
}

/* Prevent Unity's default selection colors */
.unity-base-dropdown__item:focus,
.unity-base-dropdown__item:active {
    background-color: #f0f0f0 !important;
    color: #222 !important;
}

/* Override any default Unity blue selections */
* {
    -unity-selection-color: rgba(240, 240, 240, 0.5) !important;
}

/* ==== TARGETED FIX BASED ON EXACT HIERARCHY ==== */
/* Target the content container that holds all items */
#unity-content-container,
.unity-scroll-view__content-container {
    background-color: white !important;
    background-image: none !important;
    background: white !important;
}

/* Target the content viewport */
#unity-content-viewport,
.unity-scroll-view__content-viewport {
    background-color: white !important;
    background-image: none !important;
    background: white !important;
}

/* Target the main scroll view */
.unity-scroll-view,
.unity-scroll-view--scroll {
    background-color: white !important;
    background-image: none !important;
}

/* Target dropdown container elements */
.unity-base-dropdown__container-inner,
.unity-base-dropdown__container-outer {
    background-color: white !important;
    border-radius: 8px !important;
    border: 1px solid #ddd !important;
}

/* Target ALL dropdown items and their states */
.unity-base-dropdown__item,
.unity-base-dropdown__item-content {
    background-color: white !important;
    color: #222 !important;
    padding: 8px 12px !important;
    font-size: 14px !important;
    border: none !important;
    margin: 0 !important;
}

/* CRITICAL: Target the selected/focused item (this is likely causing the blue) */
.unity-base-dropdown__item:focus,
.unity-base-dropdown__item:selected,
.unity-base-dropdown__item--selected,
.unity-base-dropdown__item:focus-visible,
.unity-base-dropdown__item[tabindex="0"] {
    background-color: #f0f0f0 !important;
    color: #222 !important;
    outline: none !important;
    border: none !important;
}

/* Target hover state */
.unity-base-dropdown__item:hover {
    background-color: #f8f8f8 !important;
    color: #222 !important;
}

/* Target the text labels inside items */
.unity-base-dropdown__label,
.unity-text-element {
    color: #222 !important;
    background-color: transparent !important;
}

/* Remove checkmarks */
.unity-base-dropdown__checkmark {
    display: none !important;
}

/* NUCLEAR OPTION: Force everything in the dropdown to be white */
.unity-base-dropdown,
.unity-base-dropdown * {
    background-color: white !important;
    background-image: none !important;
    background: white !important;
}

/* Override Unity's focus ring and selection colors */
.unity-base-dropdown__item * {
    background-color: transparent !important;
    -unity-background-image-tint-color: transparent !important;
}